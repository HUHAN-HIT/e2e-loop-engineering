{
  "name": "@e2e-loop/workspace",
  "version": "1.0.0",
  "private": true,
  "description": "e2e-loop monorepo workspace root. 不发布到 registry, 仅作为 npm workspaces 协调点.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "bun test tests-ts/",
    "publish:all": "npm publish --workspaces --access public",
    "publish:dry": "npm publish --workspaces --access public --dry-run"
  }
}